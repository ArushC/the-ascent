PORT=3001

# Relative path from the repo root for local runs:
LEADERBOARD_DB=data/leaderboard.sqlite

# Absolute path to the mounted Northflank volume for production:
# LEADERBOARD_DB=/data/leaderboard.sqlite

# Optional Daily Challenge designer agent (OpenAI-compatible).
# Leave LLM_API_KEY unset to use deterministic fallback challenges ($0).
# LLM_API_KEY=
# Defaults if LLM_BASE_URL / LLM_MODEL are omitted:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# Groq OpenAI-compatible example:
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-8b-instant

# Daily agent workflow (required only when enabling that workflow).
# CURSOR_API_KEY=
# CURSOR_WORKFLOW_MODEL=composer-2.5
# GitHub owner/repository used by Cursor cloud agents.
# WORKFLOW_REPO=ArushC/the-ascent
# WORKFLOW_DEFAULT_BRANCH=main
# Recipient for workflow notifications. Keep the real address in .env/secrets.
# WORKFLOW_EMAIL_TO=your-email@example.com
# Resend's test sender; replace after verifying a custom domain.
# WORKFLOW_EMAIL_FROM=Ascent Workflow <onboarding@resend.dev>
# RESEND_API_KEY=
