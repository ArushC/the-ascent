{
  "name": "the-ascent",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --experimental-strip-types server/index.ts",
    "dev:all": "npm run dev:server & npm run dev",
    "start": "node --experimental-strip-types server/index.ts",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "vitest",
    "test:run": "vitest run",
    "preview": "vite preview",
    "ai": "node --experimental-strip-types scripts/ai.ts",
    "ai:help": "node --experimental-strip-types scripts/ai.ts --help",
    "ai:spec": "node --experimental-strip-types scripts/ai.ts spec",
    "ai:arch": "node --experimental-strip-types scripts/ai.ts arch",
    "ai:impl": "node --experimental-strip-types scripts/ai.ts impl",
    "ai:review": "node --experimental-strip-types scripts/ai.ts review",
    "ai:debug": "node --experimental-strip-types scripts/ai.ts debug",
    "ai:refactor": "node --experimental-strip-types scripts/ai.ts refactor",
    "ai:test": "node --experimental-strip-types scripts/ai.ts test",
    "ai:feature": "node --experimental-strip-types scripts/ai.ts feature"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
